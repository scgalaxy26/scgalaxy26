    list.innerHTML = entries.map(([key, p], i) => `
      <div class="post-card">
        <div class="post-header" onclick="togglePost('pd-${i}')">
          <div>
            <p class="post-meta">${p.date}</p>
            <p class="post-title">${p.title}</p>
