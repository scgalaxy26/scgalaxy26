<script>
(function() {
  let pressTimer = null;
  const img = document.getElementById('easterEggImg');

  function triggerEasterEgg() {
    img.src = "data:image/png;base64,";
    img.style.animation = 'none';
    img.style.opacity = '1';
    void img.offsetWidth;
    img.style.animation = 'easterBurst 0.7s cubic-bezier(0.22,1,0.36,1) forwards';
  }

  const footer = document.querySelector('footer');
  footer.addEventListener('mousedown',  () => { pressTimer = setTimeout(triggerEasterEgg, 500); });
  footer.addEventListener('mouseup',    () => clearTimeout(pressTimer));
  footer.addEventListener('mouseleave', () => clearTimeout(pressTimer));
  footer.addEventListener('touchstart', () => { pressTimer = setTimeout(triggerEasterEgg, 500); }, { passive: true });
  footer.addEventListener('touchend',   () => clearTimeout(pressTimer));
})();
</script>
