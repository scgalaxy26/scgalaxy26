            }
            <div id="replies-${key}" style="margin-top:10px;display:flex;flex-direction:column;gap:8px;">
              ${p.replies ? Object.entries(p.replies).map(([rKey, r], idx) => {
                const myReplies = JSON.parse(localStorage.getItem('galaxy_my_replies')||'{}');
