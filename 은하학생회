      const myReplies = JSON.parse(localStorage.getItem('galaxy_my_poll_replies')||'{}');
      const poll = (window._pollsData||{})[pollKey];
      const reply = poll && poll.replies && poll.replies[replyKey];
      if (!reply || myReplies[replyKey] !== reply.ownerId) { showToast('본인이 작성한 댓글만 삭제할 수 있어요.'); return; }
    }
    if (!confirm('댓글을 삭제할까요?')) return;
    window._remove(window._ref(window._db,'polls/'+pollKey+'/replies/'+replyKey));
