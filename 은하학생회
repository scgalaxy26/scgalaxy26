    document.getElementById('pollImgPopup').style.display = 'none';
  }

  async function submitPoll() {
    const q = document.getElementById('pollQuestion').value.trim();
    const opts = ['pollOpt1','pollOpt2','pollOpt3','pollOpt4'].map(id => document.getElementById(id).value.trim()).filter(o=>o);
    if (!q || opts.length < 2) { showToast('질문과 선택지를 2개 이상 입력해주세요.'); return; }
    const optImgs = [];
    for (let i = 1; i <= 4; i++) {
      const file = document.getElementById('pollOptImg'+i).files[0];
      if (file) {
        const b64 = await new Promise(res => { const r = new FileReader(); r.onload = e => res(e.target.result); r.readAsDataURL(file); });
        optImgs.push(b64);
      } else {
        optImgs.push(null);
      }
    }
    const filteredImgs = optImgs.slice(0, opts.length);
    window._push(window._pollsRef, { question:q, options:opts, optImgs:filteredImgs, votes:opts.map(()=>0), allowReply: document.getElementById('pollAllowReply').checked, date:new Date().toLocaleDateString('ko-KR') });
    document.getElementById('pollQuestion').value='';
    ['pollOpt1','pollOpt2','pollOpt3','pollOpt4'].forEach(id => document.getElementById(id).value='');
    [1,2,3,4].forEach(i => { document.getElementById('pollOptImg'+i).value=''; document.getElementById('pollOptImgPreview'+i).style.display='none'; });
    showToast('투표가 생성되었습니다!');
  }

  function votePoll(key, optIdx) {
    const voted = JSON.parse(localStorage.getItem('galaxy_voted')||'{}');
    if (voted[key] !== undefined) { showToast('이미 투표했습니다.'); return; }
    const poll = (window._pollsData||{})[key];
    if (!poll) return;
    const votes = poll.votes || poll.options.map(()=>0);
    votes[optIdx] = (votes[optIdx]||0)+1;
    window._update(window._ref(window._db,'polls/'+key), { votes });
    voted[key] = optIdx;
    localStorage.setItem('galaxy_voted', JSON.stringify(voted));
    showToast('투표 완료');
  }
  function deletePoll(key) {
    if (!confirm('정말 삭제할까요?')) return;
    window._remove(window._ref(window._db,'polls/'+key));
    showToast('투표가 삭제되었습니다.');
  }
  window.renderPolls = function() {
    const data = window._pollsData||{};
    const entries = Object.entries(data).reverse();
    const list = document.getElementById('pollList');
    const empty = document.getElementById('noPolls');
    const voted = JSON.parse(localStorage.getItem('galaxy_voted')||'{}');
    if (entries.length===0) { list.innerHTML=''; empty.style.display='block'; return; }
    empty.style.display='none';
    list.innerHTML = entries.map(([key,poll]) => {
      const votes = poll.votes||poll.options.map(()=>0);
      const total = votes.reduce((a,b)=>a+b,0);
      const myVote = voted[key];
      const hasVoted = myVote!==undefined;
      return `<div class="poll-card">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:4px;">
          <p class="poll-question">📊 ${poll.question}</p>
          ${boardLoggedIn?`<button class="btn btn-danger" onclick="deletePoll('${key}')">🗑 삭제</button>`:''}
        </div>
        <div class="poll-options">
          ${poll.options.map((opt,i)=>{
            const pct = total>0?Math.round(votes[i]/total*100):0;
            const img = poll.optImgs && poll.optImgs[i];
            return `<div class="poll-option-row">
              <button class="poll-option-btn ${myVote===i?'voted':''}" onclick="${hasVoted?'':`votePoll('${key}',${i})`}" ${hasVoted&&myVote!==i?'style="cursor:default;"':''}>
                <div class="poll-bar" style="width:${hasVoted?pct:0}%"></div>
                <span class="poll-label" style="display:flex;align-items:center;gap:8px;">
                  ${img ? `<img src="${img}" onclick="event.stopPropagation();openPollImg('${key}',${i})" style="width:36px;height:36px;object-fit:cover;border-radius:6px;cursor:pointer;flex-shrink:0;" />` : ''}
                  ${myVote===i?'✔ ':''}${opt}${hasVoted?' ('+pct+'%)':''}
                </span>
              </button>
              <span class="poll-count">${hasVoted?votes[i]+'표':''}</span>
            </div>`;
          }).join('')}
        </div>
        <p class="poll-meta">${poll.date} · 총 ${total}표 ${hasVoted?'· 투표 완료':'· 클릭해서 투표하기'}</p>
        <div style="margin-top:16px;">
          ${poll.allowReply === false
            ? `<p style="font-size:0.82rem; color:var(--muted); padding:10px 0;">🚫 이 투표는 댓글이 비활성화되어 있습니다.</p>`
            : `<input class="form-input" id="poll-reply-${key}" placeholder="댓글을 입력하세요" style="width:100%;margin-bottom:8px;" />
              <button class="btn btn-outline" onclick="submitPollReply('${key}')" style="font-size:0.8rem;padding:6px 14px;">댓글 등록</button>`
          }
          <div id="poll-replies-${key}" style="margin-top:10px;display:flex;flex-direction:column;gap:8px;">
            ${poll.replies ? Object.entries(poll.replies).map(([rKey, r], idx) => {
              const myReplies = JSON.parse(localStorage.getItem('galaxy_my_poll_replies')||'{}');
              const isMine = myReplies[rKey] && myReplies[rKey] === r.ownerId;
              return `
                <div style="background:var(--bg);border-radius:8px;padding:10px 14px;font-size:0.85rem;">
                  <div style="display:flex;justify-content:space-between;align-items:center;">
                    <div>
                      <span style="color:var(--accent);font-size:0.8rem;font-weight:600;">익명${r.anonNum || idx+1}</span>
                      <span style="color:var(--muted);font-size:0.75rem;margin-left:8px;">${r.date}</span>
                    </div>
                    ${isMine || boardLoggedIn ? `<button class="btn btn-danger" onclick="deletePollReply('${key}','${rKey}')" style="font-size:0.72rem;padding:4px 8px;">삭제</button>` : ''}
                  </div>
                  <p style="margin-top:4px;">${r.text}</p>
                </div>
              `;
            }).join('') : ''}
          </div>
        </div>
      </div>`;
    }).join('');
  };

  // ── 건의함 ──
  async function submitSuggest() {
    const text = document.getElementById('suggestText').value.trim();
    if (!text) { showToast('건의 내용을 입력해주세요.'); return; }
    const link = document.getElementById('suggestLink').value.trim();
    const image = await readImagesAsObject('suggestImage');
    const now = new Date();
    window._push(window._suggestsRef, { text, link, image, answer:'', date:now.toLocaleDateString('ko-KR') });
    document.getElementById('suggestText').value='';
    document.getElementById('suggestLink').value='';
    document.getElementById('suggestImage').value='';
    document.getElementById('suggestImagePreview').innerHTML='';
    showToast('건의가 제출되었습니다. 관리자 확인 후 답변할 예정입니다.');
  }
  function loginSuggest() {
    const pw = document.getElementById('suggestPw').value;
    if (pw === SUGGEST_PASSWORD) {
      suggestLoggedIn = true;
      document.getElementById('suggestAdmin').classList.add('open');
      renderSuggests();
      showToast('관리자 모드 활성화');
