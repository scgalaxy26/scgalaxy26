  function answerSuggest(key) {
    const text = document.getElementById('answer-'+key).value.trim();
    if (!text) { showToast('답변 내용을 입력하세요.'); return; }
    window._update(window._ref(window._db,'suggests/'+key), { answer:text });
    showToast('답변이 등록되었습니다.');
  }
  function deleteSuggest(key) {
    if (!confirm('정말 삭제할까요?')) return;
    window._remove(window._ref(window._db,'suggests/'+key));
    showToast('삭제되었습니다.');
  }
  window.renderSuggests = function() {
    const data = window._suggestsData||{};
    const entries = Object.entries(data).reverse();

    if (suggestLoggedIn) {
      const adminList = document.getElementById('adminSuggestList');
      if (entries.length===0) {
        adminList.innerHTML='<p style="color:var(--muted);font-size:0.9rem;">아직 건의사항이 없어요.</p>';
      } else {
        adminList.innerHTML = entries.map(([key,s])=>`
          <div class="admin-suggest-item">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;">
              <p><strong>[${s.date}]</strong> ${s.text}</p>
              <button class="btn btn-danger" onclick="deleteSuggest('${key}')">🗑 삭제</button>
            </div>
            ${renderImages(s.image, 'suggest-image')}
            ${s.link?`<p><a href="${s.link}" target="_blank" style="color:var(--accent2);font-size:0.85rem;word-break:break-all;">🔗 ${s.link}</a></p>`:''}
            ${s.answer
              ?`<p style="color:var(--accent);font-size:0.85rem;">✔ 답변 완료: ${s.answer}</p>`
              :`<div style="display:flex;gap:8px;margin-top:8px;flex-wrap:wrap;">
                  <input class="form-input" id="answer-${key}" placeholder="답변 내용 입력" style="flex:1;min-width:0;" />
                  <button class="btn btn-primary" onclick="answerSuggest('${key}')">답변</button>
                </div>`
            }
          </div>`).join('');
      }
    }

    const answered = entries.filter(([,s])=>s.answer);
    const pubList = document.getElementById('publicSuggestList');
    const noEl = document.getElementById('noSuggests');
    if (answered.length===0) { pubList.innerHTML=''; noEl.style.display='block'; return; }
    noEl.style.display='none';
    pubList.innerHTML = answered.map(([key,s])=>`
      <div class="suggest-card">
        <p class="suggest-q">💬 ${s.text}</p>
        <p style="font-size:0.75rem; color:var(--muted);margin-top:4px;">${s.date}</p>
        ${renderImages(s.image, 'suggest-image')}
        ${s.link?`<a href="${s.link}" target="_blank" class="suggest-link">🔗 ${s.link}</a>`:''}
        <br><span class="suggest-status status-answered">답변 완료</span>
        <div class="suggest-answer">
          <strong>✦ 은하학생회 답변</strong>
          ${s.answer}
        </div>
      </div>`).join('');
  };

  renderPosts(); renderSuggests(); renderPolls();

// 팝업 관리자 로그인
function closeAdminPopup() {
  document.getElementById('adminPopup').style.display = 'none';
  document.getElementById('adminPwInput').value = '';
}
function adminLogin() {
  const pw = document.getElementById('adminPwInput').value;
  const isBoardPw = pw === BOARD_PASSWORD;
  const isSuggestPw = pw === SUGGEST_PASSWORD;
  if (isBoardPw || isSuggestPw) {
    if (isBoardPw) {
      boardLoggedIn = true;
      document.getElementById('writeForm').style.display = 'block';
      document.getElementById('pollWriteForm').style.display = 'block';
      renderPosts();
    }
    if (isSuggestPw) {
      suggestLoggedIn = true;
      document.getElementById('suggestAdmin').classList.add('open');
      renderSuggests();
      renderPolls();
    }
    closeAdminPopup();
    showToast('관리자 로그인 되었습니다!');
  } else {
    showToast('비밀번호가 틀렸습니다.');
  }
}

