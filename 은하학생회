  function previewPollOptImg(n) {
    const file = document.getElementById('pollOptImg'+n).files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = e => {
      const img = document.getElementById('pollOptImgPreview'+n);
      img.src = e.target.result;
      img.style.display = 'inline-block';
    };
    reader.readAsDataURL(file);
  }
  function openPollImg(key, idx) {
    const poll = (window._pollsData||{})[key];
    if (!poll || !poll.optImgs || !poll.optImgs[idx]) return;
    const popup = document.getElementById('pollImgPopup');
    document.getElementById('pollImgPopupImg').src = poll.optImgs[idx];
    popup.style.display = 'flex';
