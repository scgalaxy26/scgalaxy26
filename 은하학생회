          </div>
          ${boardLoggedIn ? `<button class="btn btn-danger" onclick="event.stopPropagation();deletePost('${key}')">🗑 삭제</button>` : ''}
        </div>
        <div class="post-detail" id="pd-${i}">
          <div class="post-detail-body">
            ${p.body.replace(/\n/g,'<br>')}
