  }
  
  // ── 투표 ──
  function submitPollReply(key) {
    const text = document.getElementById('poll-reply-'+key).value.trim();
    if (!text) { showToast('댓글을 입력해주세요.'); return; }
    const poll = (window._pollsData||{})[key];
    const existingReplies = poll && poll.replies ? Object.keys(poll.replies).length : 0;
    const anonNum = existingReplies + 1;
    const myId = 'u_' + Date.now() + '_' + Math.random().toString(36).slice(2,7);
