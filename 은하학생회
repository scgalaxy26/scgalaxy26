<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>은하학생회</title>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@400;700&family=Noto+Sans+KR:wght@300;400;600&display=swap" rel="stylesheet"/>

  <script type="module">
    import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
    import { getDatabase, ref, push, onValue, remove, update } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-database.js";

    const firebaseConfig = {
      apiKey: "AIzaSyCeMurbwJyJA5QpQOGWQHVjZ0tkP7PKSog",
      authDomain: "galaxy-council.firebaseapp.com",
      databaseURL: "https://galaxy-council-default-rtdb.firebaseio.com",
      projectId: "galaxy-council",
      storageBucket: "galaxy-council.firebasestorage.app",
      messagingSenderId: "1089635315923",
      appId: "1:1089635315923:web:6756b565c0076b18dde426",
      measurementId: "G-YLEBPLYN3Q"
    };

    const app = initializeApp(firebaseConfig);
    const db = getDatabase(app);
    const postsRef = ref(db, 'posts');
    const suggestsRef = ref(db, 'suggests');
    const pollsRef = ref(db, 'polls');

    window._db = db; window._ref = ref; window._push = push;
    window._onValue = onValue; window._remove = remove; window._update = update;
    window._postsRef = postsRef; window._suggestsRef = suggestsRef; window._pollsRef = pollsRef;
    window._firebaseReady = true;

    onValue(postsRef, snap => {
      window._postsData = snap.val() || {};
      if (typeof window.renderPosts === 'function') window.renderPosts();
    });
    onValue(suggestsRef, snap => {
      window._suggestsData = snap.val() || {};
      if (typeof window.renderSuggests === 'function') window.renderSuggests();
    });
    onValue(pollsRef, snap => {
      window._pollsData = snap.val() || {};
      if (typeof window.renderPolls === 'function') window.renderPolls();
    });
  </script>

  <style>
    :root {
      --bg: #050a18; --surface: #0d1630; --surface2: #111d3c;
      --accent: #a78bfa; --accent2: #60a5fa; --star: #e0e7ff;
      --text: #e2e8f0; --muted: #94a3b8;
      --border: rgba(167,139,250,0.2); --glow: 0 0 20px rgba(167,139,250,0.3);
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Noto Sans KR', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; }
    #stars-canvas { position: fixed; top:0; left:0; width:100%; height:100%; pointer-events:none; z-index:0; }
    nav {
      position: fixed; top:0; left:0; right:0; z-index:100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 16px 48px;
      background: rgba(5,10,24,0.85); backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
    }
    .nav-logo { font-family:'Noto Serif KR',serif; font-size:1.4rem; font-weight:700; color:var(--accent); letter-spacing:0.05em; }
    .nav-logo span { color: var(--accent2); }
    .nav-links { display:flex; gap:32px; list-style:none; }
    .nav-links li a { color:var(--muted); text-decoration:none; font-size:0.92rem; transition:color 0.2s; }
    .nav-links li a:hover { color:var(--accent); }
    @media (max-width: 768px) {
  nav {
    padding: 12px 16px;
    flex-wrap: nowrap;
    overflow: hidden;
  }
  .nav-logo {
    font-size: 1rem;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .nav-links {
    gap: 12px;
    flex-shrink: 1;
    overflow: hidden;
  }
  .nav-links li a {
    font-size: 0.78rem;
    white-space: nowrap;
  }
}
    section { position:relative; z-index:1; padding:120px 48px 80px; max-width:1100px; margin:0 auto; }
    .section-title { font-family:'Noto Serif KR',serif; font-size:2rem; font-weight:700; color:var(--accent); margin-bottom:8px; }
    .section-sub { color:var(--muted); font-size:0.9rem; margin-bottom:24px; }
    .divider { height:1px; background:linear-gradient(90deg,var(--accent),transparent); margin-bottom:24px; }
    #home { min-height:100vh; display:flex; flex-direction:column; justify-content:center; align-items:center; text-align:center; padding-top:80px; }
    .hero-badge { display:inline-block; background:rgba(167,139,250,0.1); border:1px solid var(--border); color:var(--accent); font-size:0.8rem; padding:6px 18px; border-radius:99px; margin-bottom:24px; letter-spacing:0.1em; }
    .hero-title { font-family:'Noto Serif KR',serif; font-size:clamp(2.5rem,6vw,4.5rem); font-weight:700; line-height:1.2; margin-bottom:16px; }
    .hero-title .galaxy { color:var(--accent); }
    .hero-desc { color:var(--muted); font-size:1.1rem; max-width:500px; line-height:1.7; margin-bottom:40px; }
    .hero-buttons { display:flex; gap:16px; flex-wrap:wrap; justify-content:center; }
    .btn { padding:12px 28px; border-radius:8px; font-size:0.95rem; cursor:pointer; border:none; font-family:inherit; transition:all 0.2s; }
    .btn-primary { background:var(--accent); color:#0d0520; font-weight:600; }
    .btn-primary:hover { box-shadow:var(--glow); transform:translateY(-2px); }
    .btn-outline { background:transparent; color:var(--accent); border:1px solid var(--border); }
    .btn-outline:hover { background:rgba(167,139,250,0.1); }
    .btn-danger { background:rgba(239,68,68,0.12); color:#f87171; border:1px solid rgba(239,68,68,0.25); font-size:0.8rem; padding:6px 12px; }
    .btn-danger:hover { background:rgba(239,68,68,0.22); }
    .tab-bar { display:flex; gap:4px; background:var(--surface); border-radius:12px; padding:4px; margin-bottom:40px; width:100%; }
    .tab-btn { padding:10px 0; border-radius:8px; border:none; background:transparent; color:var(--muted); font-family:inherit; font-size:0.95rem; cursor:pointer; transition:all 0.2s; flex:1; white-space:nowrap; text-align:center; }
    .tab-btn.active { background:var(--accent); color:#0d0520; font-weight:600; }
    .tab-panel { display:none; } .tab-panel.active { display:block; }
    .officer-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:20px; }
    .officer-card { background:var(--surface); border:1px solid var(--border); border-radius:16px; padding:24px 28px; display:flex; flex-direction:row; align-items:center; gap:20px; transition:transform 0.2s, box-shadow 0.2s; }
    .officer-card:hover { transform:translateY(-4px); box-shadow:var(--glow); }
    .officer-avatar { width:72px; height:72px; border-radius:50%; background:linear-gradient(135deg,var(--accent),var(--accent2)); flex-shrink:0; display:flex; align-items:center; justify-content:center; font-size:1.8rem; }
    .officer-info { display:flex; flex-direction:column; text-align:left; }
    .officer-role { font-size:0.75rem; color:var(--accent); letter-spacing:0.08em; margin-bottom:4px; }
    .officer-name { font-size:1.1rem; font-weight:600; margin-bottom:6px; }
    .officer-desc { font-size:0.83rem; color:var(--muted); line-height:1.6; }
    .promise-list { display:flex; flex-direction:column; gap:20px; }
    .promise-card { background:var(--surface); border:1px solid var(--border); border-radius:16px; padding:28px 32px; display:flex; gap:20px; align-items:flex-start; transition:transform 0.2s; }
    .promise-card:hover { transform:translateX(4px); }
    .promise-icon { font-size:2.2rem; flex-shrink:0; line-height:1; margin-top:2px; }
    .promise-title { font-size:1.05rem; font-weight:600; margin-bottom:8px; }
    .promise-body { font-size:0.9rem; color:var(--muted); line-height:1.7; }
    .admin-login-box { background:var(--surface); border:1px solid var(--border); border-radius:16px; padding:32px; max-width:420px; margin-bottom:40px; }
    .admin-login-box h3 { margin-bottom:16px; font-size:1rem; }
    .form-row { display:flex; gap:12px; margin-bottom:12px; }
    .form-input { flex:1; background:var(--bg); border:1px solid var(--border); border-radius:8px; padding:10px 14px; color:var(--text); font-family:inherit; font-size:0.9rem; outline:none; }
    .form-input:focus { border-color:var(--accent); }
    textarea.form-input { resize:vertical; min-height:100px; }
    .post-list { display:flex; flex-direction:column; gap:16px; }
    .post-card { background:var(--surface); border:1px solid var(--border); border-radius:12px; padding:24px 28px; transition:all 0.2s; }
    .post-card:hover { border-color:var(--accent); }
    .post-header { display:flex; justify-content:space-between; align-items:flex-start; cursor:pointer; }
    .post-meta { font-size:0.78rem; color:var(--muted); margin-bottom:8px; }
    .post-title { font-size:1.05rem; font-weight:600; margin-bottom:8px; }
    .post-preview { font-size:0.88rem; color:var(--muted); }
    .post-detail { display:none; margin-top:16px; }
    .post-detail.open { display:block; }
    .post-detail-body { background:var(--bg); border-radius:8px; padding:20px; font-size:0.92rem; line-height:1.8; color:var(--text); }
    .post-image { max-width:100%; border-radius:8px; margin-top:12px; display:block; }
    .post-link { display:inline-block; margin-top:10px; color:var(--accent2); font-size:0.88rem; word-break:break-all; }
    .poll-card { background:var(--surface); border:1px solid var(--border); border-radius:16px; padding:28px 32px; margin-bottom:20px; }
    .poll-question { font-size:1.05rem; font-weight:600; margin-bottom:16px; }
    .poll-options { display:flex; flex-direction:column; gap:10px; }
    .poll-option-row { display:flex; align-items:center; gap:10px; }
    .poll-option-btn { flex:1; background:var(--bg); border:1px solid var(--border); border-radius:8px; padding:10px 16px; color:var(--text); font-family:inherit; font-size:0.9rem; cursor:pointer; text-align:left; transition:all 0.2s; position:relative; overflow:hidden; }
    .poll-option-btn:hover { border-color:var(--accent); }
    .poll-option-btn.voted { border-color:var(--accent); background:rgba(167,139,250,0.08); }
    .poll-bar { position:absolute; left:0; top:0; bottom:0; background:rgba(167,139,250,0.15); transition:width 0.5s; border-radius:8px; }
    .poll-label { position:relative; z-index:1; }
    .poll-count { font-size:0.8rem; color:var(--muted); min-width:50px; }
    .poll-meta { font-size:0.78rem; color:var(--muted); margin-top:12px; }
    .suggest-form { background:var(--surface); border:1px solid var(--border); border-radius:16px; padding:32px; max-width:600px; margin-bottom:48px; }
    .suggest-form h3 { margin-bottom:20px; font-size:1rem; }
    .suggest-list { display:flex; flex-direction:column; gap:20px; }
    .suggest-card { background:var(--surface); border:1px solid var(--border); border-radius:12px; padding:24px; }
    .suggest-q { font-size:0.95rem; margin-bottom:6px; }
    .suggest-status { display:inline-block; font-size:0.75rem; padding:3px 10px; border-radius:99px; margin-bottom:12px; }
    .status-answered { background:rgba(52,211,153,0.15); color:#34d399; }
    .suggest-answer { background:rgba(167,139,250,0.08); border-left:3px solid var(--accent); padding:12px 16px; border-radius:0 8px 8px 0; font-size:0.88rem; line-height:1.7; color:var(--muted); }
    .suggest-answer strong { color:var(--accent); display:block; margin-bottom:4px; font-size:0.8rem; }
    .suggest-image { max-width:100%; border-radius:8px; margin-top:10px; display:block; }
    .suggest-link { display:inline-block; margin-top:8px; color:var(--accent2); font-size:0.88rem; word-break:break-all; }
    .admin-panel { display:none; background:var(--surface2); border:1px solid var(--accent); border-radius:12px; padding:24px; margin-top:16px; margin-bottom:32px; overflow:hidden; }
    .admin-panel.open { display:block; }
    .admin-suggest-item { background:var(--bg); border-radius:8px; padding:16px; margin-bottom:16px; }
    .admin-suggest-item p { font-size:0.9rem; margin-bottom:10px; }
    #backToTop { position:fixed; bottom:32px; left:32px; z-index:200; width:52px; height:52px; border-radius:50%; background:var(--accent); color:#0d0520; border:none; font-size:1.3rem; cursor:pointer; box-shadow:var(--glow); display:flex; align-items:center; justify-content:center; transition:all 0.3s; opacity:0; pointer-events:none; }
    #backToTop.show { opacity:1; pointer-events:auto; }
    #backToTop:hover { transform:translateY(-3px); box-shadow:0 0 30px rgba(167,139,250,0.5); }
    footer { position:relative; z-index:1; text-align:center; padding:40px; border-top:1px solid var(--border); color:var(--muted); font-size:0.85rem; }
    #toast { position:fixed; bottom:32px; right:32px; background:var(--accent); color:#0d0520; font-weight:600; padding:12px 24px; border-radius:8px; font-size:0.9rem; z-index:999; opacity:0; transform:translateY(10px); transition:all 0.3s; pointer-events:none; }
    #toast.show { opacity:1; transform:translateY(0); }
    .fade-in { opacity:0; transform:translateY(20px); transition:opacity 0.6s, transform 0.6s; }
    .fade-in.visible { opacity:1; transform:translateY(0); }
    .file-label { display:inline-flex; align-items:center; gap:6px; background:var(--surface2); border:1px dashed var(--border); border-radius:8px; padding:8px 16px; color:var(--muted); font-size:0.85rem; cursor:pointer; transition:all 0.2s; }
    .file-label:hover { border-color:var(--accent); color:var(--accent); }
    input[type="file"] { display:none; }
    @keyframes easterBurst {
      0%   { transform: scale(0); opacity: 1; }
      60%  { transform: scale(1.3); opacity: 1; }
      100% { transform: scale(4); opacity: 0; }
    }
  </style>
</head>
<body>

<canvas id="stars-canvas"></canvas>
<button id="backToTop" onclick="window.scrollTo({top:0,behavior:'smooth'})" title="처음으로 ↑">🔝</button>

<nav>
  <div class="nav-logo">✦ 은하<span>학생회</span> ✦</div>
  <ul class="nav-links">
    <li><a href="#intro">학생회 소개</a></li>
    <li><a href="#board">게시판</a></li>
    <li><a href="#suggest">건의함</a></li>
  </ul>
</nav>

<section id="home">
  <div class="hero-badge">2026년도 성심여자고등학교</div>
  <h1 class="hero-title">은하<br><span class="galaxy">학생회</span></h1>
  <p class="hero-desc">학생 여러분과 함께 성장하는 은하학생회가 되겠습니다.</p>
  <div class="hero-buttons">
    <button class="btn btn-primary" onclick="scrollToSection('intro')">학생회 소개 보기</button>
    <button class="btn btn-primary" onclick="scrollToSection('board')">게시판</button>
    <button class="btn btn-primary" onclick="scrollToSection('suggest')">건의하기</button>
  </div>
</section>

<section id="intro" class="fade-in">
  <p class="section-title">학생회 소개</p>
  <p class="section-sub">은하학생회 의미, 임원 소개, 공약 소개</p>
  <div class="divider"></div>
  <div class="tab-bar">
    <button class="tab-btn active" onclick="switchTab('meaning', this)">✨ 은하학생회 의미</button>
    <button class="tab-btn" onclick="switchTab('officers', this)">👤 임원 소개</button>
    <button class="tab-btn" onclick="switchTab('promises', this)">📋 공약 소개</button>
  </div>

  <div id="tab-meaning" class="tab-panel active">
    <p style="font-size:1rem; line-height:2; color:var(--muted);">
      은하학생회는 학생 한 명 한 명이 모두 별이라는 생각에서 출발했습니다. <br>은하는 별들에게 빛날 자리를 제공해주는 존재이며 빛나는 별들의 모임입니다.<br>저희는 학교를 모든 별, 즉 학생들이 자신의 빛을 발할 수 있는 공간인 은하처럼 만들고자 합니다. <br>학생회로서 학생들에게 더 즐겁고 편리한 학교 생활을 만들어주고 나아가 학생들이 학교를 더 좋아하도록 만드는 것이 은하학생회의 목표입니다.
    </p>
  </div>

  <div id="tab-officers" class="tab-panel">
    <div style="display:flex; flex-direction:column; gap:32px;"> 
        <div>
      <p style="font-size:0.8rem; color:var(--accent); letter-spacing:0.1em; margin-bottom:12px;">★ 회장단</p>
      <div class="officer-grid">
        <div class="officer-card">
          <div class="officer-avatar">🌟</div>
          <div class="officer-info">
            <p class="officer-role">학생회장</p>
            <p class="officer-name">강가림</p>
            <p class="officer-desc">학교 생활이 힘들 때도 즐거울 때도 항상 여러분 곁에 있는 학생회장이 되겠습니다.</p>
          </div>
        </div>
        <div class="officer-card">
          <div class="officer-avatar">⭐</div>
          <div class="officer-info">
            <p class="officer-role">학생부회장</p>
            <p class="officer-name">송다인</p>
            <p class="officer-desc">여러분의 가능성이 빛날 수 있도록, 작은 별도 놓치지 않는 학생부회장이 되겠습니다.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- 기획부 -->
    <div>
      <p style="font-size:0.8rem; color:var(--accent); letter-spacing:0.1em; margin-bottom:12px;">✦ 기획부</p>
      <div class="officer-grid">
        <div class="officer-card">
          <div class="officer-avatar">✨</div>
          <div class="officer-info">
            <p class="officer-role">기획부 부장</p>
            <p class="officer-name">신다형</p>
            <p class="officer-desc">행동으로 실천하는 학생회 임원이 되겠습니다.</p>
          </div>
        </div>
        <div class="officer-card">
          <div class="officer-avatar">💫</div>
          <div class="officer-info">
            <p class="officer-role">기획부 부원</p>
            <p class="officer-name">권재은</p>
            <p class="officer-desc">학교 생활에 즐거움을 줄 수 있는 학생회 임원이 되겠습니다.</p>
          </div>
        </div>
        <div class="officer-card">
          <div class="officer-avatar">💫</div>
          <div class="officer-info">
            <p class="officer-role">기획부 부원</p>
            <p class="officer-name">나예지</p>
            <p class="officer-desc">밝은 나예지입니다.</p>
          </div>
        </div>
        <div class="officer-card">
          <div class="officer-avatar">💫</div>
          <div class="officer-info">
            <p class="officer-role">기획부 부원</p>
            <p class="officer-name">이유주</p>
