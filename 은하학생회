                `;
              }).join('') : ''}
            </div>
          </div>
        </div>
      </div> 
    `).join('');
  };

  function togglePost(id) { document.getElementById(id).classList.toggle('open'); }

  function likePost(key) {
    const post = (window._postsData||{})[key];
    if (!post) return;
    window._update(window._ref(window._db,'posts/'+key), { likes: (post.likes||0)+1 });
  }

  function submitReply(key) {
    const text = document.getElementById('reply-'+key).value.trim();
    if (!text) { showToast('댓글을 입력해주세요.'); return; }
    const post = (window._postsData||{})[key];
    const existingReplies = post && post.replies ? Object.keys(post.replies).length : 0;
    const anonNum = existingReplies + 1;
    const myId = 'u_' + Date.now() + '_' + Math.random().toString(36).slice(2,7);
    const replyRef = window._push(window._ref(window._db,'posts/'+key+'/replies'), { text, date: new Date().toLocaleDateString('ko-KR'), anonNum, ownerId: myId });
    const myReplies = JSON.parse(localStorage.getItem('galaxy_my_replies')||'{}');
    myReplies[replyRef.key] = myId;
    localStorage.setItem('galaxy_my_replies', JSON.stringify(myReplies));
    document.getElementById('reply-'+key).value = '';
    showToast('댓글이 등록되었습니다.');
  }

  function deleteReply(postKey, replyKey) {
    if (!boardLoggedIn) {
      const myReplies = JSON.parse(localStorage.getItem('galaxy_my_replies')||'{}');
      const post = (window._postsData||{})[postKey];
      const reply = post && post.replies && post.replies[replyKey];
      if (!reply || myReplies[replyKey] !== reply.ownerId) { showToast('본인이 작성한 댓글만 삭제할 수 있어요.'); return; }
