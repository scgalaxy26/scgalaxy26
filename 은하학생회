    const now = new Date();
    window._push(window._postsRef, {
      title, body, link, image,
      allowReply: document.getElementById('postAllowReply').checked,
      date: now.toLocaleDateString('ko-KR')+' '+now.toLocaleTimeString('ko-KR',{hour:'2-digit',minute:'2-digit'})
